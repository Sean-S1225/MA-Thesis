@article{hermeking1433sP53RegulatedInhibitor1997,
  title = {\mkbibemph{14-3-3sigma} {{Is}} a P53-{{Regulated Inhibitor}} of {{G2}}/{{M Progression}}},
  author = {Hermeking, Heiko and Lengauer, Christoph and Polyak, Kornelia and He, Tong-Chuan and Zhang, Lin and Thiagalingam, Sam and Kinzler, Kenneth W and Vogelstein, Bert},
