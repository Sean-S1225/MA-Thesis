@article{garcia-pinoAllosteryIntrinsicDisorder2010,
  title = {Allostery and {{Intrinsic Disorder Mediate Transcription Regulation}} by {{Conditional Cooperativity}}},
  author = {Garcia-Pino, Abel and Balasubramanian, Sreeram and Wyns, Lode and Gazit, Ehud and De Greve, Henri and Magnuson, Roy D. and Charlier, Daniel and family=Nuland, given=Nico A. J., prefix=van, useprefix=true and Loris, Remy},
  date = {2010-07-09},
  journaltitle = {Cell},
  shortjournal = {Cell},
  volume = {142},
  number = {1},
