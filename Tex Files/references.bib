  keywords = {Amino Acid Sequence,Animals,Apoptosis,Base Sequence,bcl-2-Associated X Protein,Blotting Western,Cell Line,Cloning Molecular,Conserved Sequence,Humans,Macromolecular Substances,Mice,Molecular Sequence Data,Polymerase Chain Reaction,Proto-Oncogene Proteins,Proto-Oncogene Proteins c-bcl-2,Restriction Mapping,Sequence Homology Amino Acid}
}

@article{miyashitaTumorSuppressorP531995,
  title = {Tumor Suppressor P53 Is a Direct Transcriptional Activator of the Human Bax Gene},
  author = {Miyashita, T. and Reed, J. C.},
  date = {1995-01-27},
  journaltitle = {Cell},
  shortjournal = {Cell},
