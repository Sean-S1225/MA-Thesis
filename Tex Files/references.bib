@article{scharerMammalianP53Can1992,
  title = {Mammalian P53 Can Function as a Transcription Factor in Yeast},
  author = {Schärer, E. and Iggo, R.},
  date = {1992-04-11},
  journaltitle = {Nucleic Acids Research},
  shortjournal = {Nucleic Acids Res},
  volume = {20},
